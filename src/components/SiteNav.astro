<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 200;
    background: rgba(250, 250, 249, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-stone-200);
  }

  .nav-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0.875rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .nav-logo {
    width: 1.6rem;
    height: auto;
    color: var(--color-orange-500);
    flex-shrink: 0;
  }

  .nav-wordmark {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-stone-800);
  }

  .nav-links {
    display: flex;
    gap: 1.75rem;
    align-items: center;
  }

  .nav-link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-stone-600);
    transition: color 0.15s;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--color-orange-500);
  }

  .nav-link-demo {
    color: var(--color-orange-500);
    font-weight: 600;
  }
  .nav-link-demo:hover {
    color: var(--color-orange-600);
  }

  .nav-link-login {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-stone-500);
    margin-left: 0.25rem;
    flex-shrink: 0;
  }
  .nav-link-login:hover,
  .nav-link-login:focus-visible {
    color: var(--color-stone-800);
  }
  .nav-link-login:focus-visible {
    outline: 2px solid var(--color-orange-500);
    outline-offset: 3px;
    border-radius: 0.25rem;
  }

  .nav-login-icon {
    width: 1.1rem;
    height: 1.1rem;
  }

  @media (max-width: 640px) {
    .nav-inner {
      padding: 0.75rem 1rem;
    }
    .nav-wordmark {
      font-size: 1.05rem;
    }
    .nav-links {
      gap: 0.875rem;
    }
    .nav-link {
      font-size: 0.8125rem;
    }
    .nav-link-login {
      min-width: 2.75rem;
      min-height: 2.75rem;
      justify-content: center;
      margin-left: 0;
    }
    .nav-login-icon {
      width: 1.25rem;
      height: 1.25rem;
    }
    .nav-login-text {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }
</style>
